{
  "name": "archery-scores-backend",
  "version": "1.0.0",
  "description": "Backend server for archery scores bulk uploader - handles Excel file processing and API proxy",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "TEST_MODE=true node server.js",
    "test:dev": "TEST_MODE=true nodemon server.js",
    "mock": "node mock-server.js",
    "mock:dev": "nodemon mock-server.js",
    "test:full": "concurrently \"npm run mock\" \"npm run test\""
  },
  "dependencies": {
    "axios": "^1.6.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.2",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "fs": "^0.0.1-security",
    "multer": "^1.4.5-lts.1",
    "path": "^0.12.7"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "^3.0.2"
  },
  "keywords": [
    "archery",
    "scores",
    "excel",
    "api",
    "proxy"
  ],
  "author": "David Cook",
  "license": "MIT"
}
